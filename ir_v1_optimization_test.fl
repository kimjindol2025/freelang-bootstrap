// ================================================================
// FreeLang IR v1.0 - Runtime Optimization Test Suite
// ================================================================
//
// 목적: Runtime 최적화의 완전한 검증
// 상태: Production-Ready (Phase C Week 3)
//
// 구성:
//   1. Unit Tests (Individual Optimizations)
//   2. Integration Tests (Multiple Optimizations)
//   3. Performance Tests (Speedup Measurement)
//   4. Correctness Tests (Semantic Preservation)
//   5. Edge Case Tests
//
// ================================================================

import ir_v1_kernel
import ir_v1_runtime_optimization

// ================================================================
// Test Framework
// ================================================================

var test_passed = 0
var test_failed = 0

fn assert(condition: bool, test_name: string) {
    if condition {
        println("  ✅ PASS: " + test_name)
        test_passed = test_passed + 1
    } else {
        println("  ❌ FAIL: " + test_name)
        test_failed = test_failed + 1
    }
}

fn test_header(name: string) {
    println("\n" + "=" * 70)
    println("TEST: " + name)
    println("=" * 70)
}

fn test_footer() {
    println("")
}

// ================================================================
// Part 1: Unit Tests - Constant Folding
// ================================================================

fn test_constant_folding_add() {
    test_header("Constant Folding: ADD")

    ir_v1_kernel.init()

    ir_v1_kernel.add_instruction("LOAD", [1, "int", 5])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 3])
    ir_v1_kernel.add_instruction("ADD", [1, 5, 3])
    ir_v1_kernel.add_instruction("HALT", [0])

    var program_before = len(ir_v1_kernel.get_program())

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.optimize_constant_folding()

    var stats = ir_v1_runtime_optimization.get_stats()
    assert(stats["foldedConstants"] > 0, "Should fold constant ADD")

    test_footer()
}

fn test_constant_folding_mul() {
    test_header("Constant Folding: MUL")

    ir_v1_kernel.init()

    ir_v1_kernel.add_instruction("LOAD", [1, "int", 4])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 6])
    ir_v1_kernel.add_instruction("MUL", [1, 4, 6])
    ir_v1_kernel.add_instruction("HALT", [0])

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.optimize_constant_folding()

    var stats = ir_v1_runtime_optimization.get_stats()
    assert(stats["foldedConstants"] > 0, "Should fold constant MUL")

    test_footer()
}

// ================================================================
// Part 2: Unit Tests - Dead Code Elimination
// ================================================================

fn test_dead_code_nop_removal() {
    test_header("Dead Code Elimination: NOP Removal")

    ir_v1_kernel.init()

    ir_v1_kernel.add_instruction("LOAD", [1, "int", 10])
    ir_v1_kernel.add_instruction("NO_OP", [])
    ir_v1_kernel.add_instruction("ADD", [1, 10, 5])
    ir_v1_kernel.add_instruction("NO_OP", [])
    ir_v1_kernel.add_instruction("NO_OP", [])
    ir_v1_kernel.add_instruction("HALT", [0])

    var program_before = len(ir_v1_kernel.get_program())

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.optimize_dead_code_elimination()

    var stats = ir_v1_runtime_optimization.get_stats()
    assert(stats["removedInstructions"] == 3, "Should remove 3 NO_OP instructions")

    test_footer()
}

fn test_dead_code_multiple_nops() {
    test_header("Dead Code Elimination: Multiple NOPs")

    ir_v1_kernel.init()

    var i = 0
    while i < 5 {
        ir_v1_kernel.add_instruction("NO_OP", [])
        i = i + 1
    }
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 1])
    ir_v1_kernel.add_instruction("HALT", [0])

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.optimize_dead_code_elimination()

    var stats = ir_v1_runtime_optimization.get_stats()
    assert(stats["removedInstructions"] == 5, "Should remove 5 NOPs")

    test_footer()
}

// ================================================================
// Part 3: Unit Tests - Instruction Combining
// ================================================================

fn test_instruction_combining_duplicate_load() {
    test_header("Instruction Combining: Duplicate LOAD")

    ir_v1_kernel.init()

    ir_v1_kernel.add_instruction("LOAD", [1, "int", 42])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 42])
    ir_v1_kernel.add_instruction("ADD", [1, 42, 42])
    ir_v1_kernel.add_instruction("HALT", [0])

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.optimize_instruction_combining()

    var stats = ir_v1_runtime_optimization.get_stats()
    assert(stats["combinedInstructions"] > 0, "Should combine duplicate LOAD")

    test_footer()
}

fn test_instruction_combining_allocate_load() {
    test_header("Instruction Combining: ALLOCATE + LOAD Sequence")

    ir_v1_kernel.init()

    ir_v1_kernel.add_instruction("ALLOCATE_MEMORY", [0x1000, 512])
    ir_v1_kernel.add_instruction("LOAD", [0x1000, "int", 99])
    ir_v1_kernel.add_instruction("HALT", [0])

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.optimize_instruction_combining()

    var stats = ir_v1_runtime_optimization.get_stats()
    assert(stats["combinedInstructions"] > 0, "Should combine ALLOCATE + LOAD")

    test_footer()
}

// ================================================================
// Part 4: Integration Tests - Multiple Optimizations
// ================================================================

fn test_combined_constant_folding_and_dead_code() {
    test_header("Combined: Constant Folding + Dead Code Elimination")

    ir_v1_kernel.init()

    ir_v1_kernel.add_instruction("LOAD", [1, "int", 10])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 20])
    ir_v1_kernel.add_instruction("ADD", [1, 10, 20])
    ir_v1_kernel.add_instruction("NO_OP", [])
    ir_v1_kernel.add_instruction("NO_OP", [])
    ir_v1_kernel.add_instruction("HALT", [0])

    var program_before = len(ir_v1_kernel.get_program())

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.run()

    var stats = ir_v1_runtime_optimization.get_stats()
    var reduction = stats["originalInstructions"] - stats["optimizedInstructions"]

    assert(reduction > 0, "Should reduce program size")
    assert(stats["foldedConstants"] + stats["removedInstructions"] > 0,
           "Should apply multiple optimizations")

    test_footer()
}

fn test_full_optimization_pipeline() {
    test_header("Full Optimization Pipeline")

    ir_v1_kernel.init()

    // Complex program
    ir_v1_kernel.add_instruction("CREATE_PROCESS", [1, "P1", 5])
    ir_v1_kernel.add_instruction("ALLOCATE_MEMORY", [0x1000, 1024])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 100])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 50])
    ir_v1_kernel.add_instruction("ADD", [1, 100, 50])
    ir_v1_kernel.add_instruction("NO_OP", [])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 100])
    ir_v1_kernel.add_instruction("MUL", [1, 150, 10])
    ir_v1_kernel.add_instruction("DEALLOCATE_MEMORY", [0x1000, 1024])
    ir_v1_kernel.add_instruction("HALT", [0])

    var program_size_before = len(ir_v1_kernel.get_program())

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.run()

    var stats = ir_v1_runtime_optimization.get_stats()
    var program_size_after = stats["optimizedInstructions"]

    assert(program_size_after < program_size_before, "Should reduce program size")
    assert(program_size_after > 0, "Should not eliminate entire program")

    test_footer()
}

// ================================================================
// Part 5: Performance Tests
// ================================================================

fn test_performance_large_program() {
    test_header("Performance: Large Program Optimization")

    ir_v1_kernel.init()

    // Generate large program with opportunities
    var i = 0
    while i < 50 {
        ir_v1_kernel.add_instruction("LOAD", [1, "int", i])
        ir_v1_kernel.add_instruction("ADD", [1, i, i])
        if i % 5 == 0 {
            ir_v1_kernel.add_instruction("NO_OP", [])
        }
        i = i + 1
    }
    ir_v1_kernel.add_instruction("HALT", [0])

    var size_before = len(ir_v1_kernel.get_program())

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.run()

    var stats = ir_v1_runtime_optimization.get_stats()
    var size_after = stats["optimizedInstructions"]

    assert(size_after < size_before, "Should optimize large programs")
    assert(stats["executionTimeReduction"] > 0, "Should show positive reduction")

    println("\n  Performance Metrics:")
    println("    Size Before: " + size_before)
    println("    Size After: " + size_after)
    println("    Reduction: " + (size_before - size_after) + " instructions")

    test_footer()
}

// ================================================================
// Part 6: Correctness Tests
// ================================================================

fn test_correctness_optimization_preserves_semantics() {
    test_header("Correctness: Optimization Preserves Semantics")

    ir_v1_kernel.init()

    ir_v1_kernel.add_instruction("LOAD", [1, "int", 5])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 3])
    ir_v1_kernel.add_instruction("ADD", [1, 5, 3])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 2])
    ir_v1_kernel.add_instruction("MUL", [1, 8, 2])
    ir_v1_kernel.add_instruction("HALT", [0])

    // Run without optimization
    var result1 = ir_v1_kernel.execute()

    // Reset and run with optimization
    ir_v1_kernel.init()
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 5])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 3])
    ir_v1_kernel.add_instruction("ADD", [1, 5, 3])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 2])
    ir_v1_kernel.add_instruction("MUL", [1, 8, 2])
    ir_v1_kernel.add_instruction("HALT", [0])

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.run()
    var result2 = ir_v1_kernel.execute()

    assert(result1["executedInstructions"] > 0, "Should execute unoptimized")
    assert(result2["executedInstructions"] > 0, "Should execute optimized")
    assert(result1["successfulExecutions"] > 0, "Should succeed unoptimized")

    test_footer()
}

// ================================================================
// Part 7: Edge Cases
// ================================================================

fn test_empty_program_optimization() {
    test_header("Edge Case: Empty Program")

    ir_v1_kernel.init()

    ir_v1_runtime_optimization.reset()
    var stats = ir_v1_runtime_optimization.run()

    assert(stats["originalInstructions"] == 0, "Empty program should have 0 instructions")

    test_footer()
}

fn test_single_instruction_optimization() {
    test_header("Edge Case: Single Instruction")

    ir_v1_kernel.init()
    ir_v1_kernel.add_instruction("HALT", [0])

    ir_v1_runtime_optimization.reset()
    var stats = ir_v1_runtime_optimization.run()

    assert(stats["optimizedInstructions"] <= 1, "Should preserve single instruction")

    test_footer()
}

fn test_no_optimization_opportunity() {
    test_header("Edge Case: No Optimization Opportunity")

    ir_v1_kernel.init()

    ir_v1_kernel.add_instruction("CREATE_PROCESS", [1, "P1", 5])
    ir_v1_kernel.add_instruction("DEBUG_PRINT", ["Test"])
    ir_v1_kernel.add_instruction("HALT", [0])

    var size_before = len(ir_v1_kernel.get_program())

    ir_v1_runtime_optimization.reset()
    var stats = ir_v1_runtime_optimization.run()

    assert(stats["optimizedInstructions"] == size_before,
           "Should not change program with no optimization opportunities")

    test_footer()
}

// ================================================================
// Part 8: Configuration Tests
// ================================================================

fn test_disable_optimizations() {
    test_header("Configuration: Disable Optimizations")

    ir_v1_kernel.init()

    ir_v1_kernel.add_instruction("LOAD", [1, "int", 10])
    ir_v1_kernel.add_instruction("LOAD", [1, "int", 20])
    ir_v1_kernel.add_instruction("ADD", [1, 10, 20])
    ir_v1_kernel.add_instruction("NO_OP", [])
    ir_v1_kernel.add_instruction("HALT", [0])

    // Disable all optimizations
    ir_v1_runtime_optimization.set_option("constantFolding", false)
    ir_v1_runtime_optimization.set_option("deadCodeElimination", false)
    ir_v1_runtime_optimization.set_option("instructionCombining", false)

    var size_before = len(ir_v1_kernel.get_program())

    ir_v1_runtime_optimization.reset()
    ir_v1_runtime_optimization.run()

    var stats = ir_v1_runtime_optimization.get_stats()

    assert(stats["removedInstructions"] == 0, "Should not remove dead code when disabled")

    test_footer()
}

// ================================================================
// Part 9: Test Summary
// ================================================================

fn print_test_summary() {
    println("\n" + "=" * 70)
    println("TEST SUMMARY")
    println("=" * 70)
    println("Passed: " + test_passed + " ✅")
    println("Failed: " + test_failed + " ❌")
    println("Total:  " + (test_passed + test_failed))

    if test_passed + test_failed > 0 {
        var pass_rate = (test_passed * 100) / (test_passed + test_failed)
        println("Pass Rate: " + pass_rate + "%")
    }

    if test_failed == 0 {
        println("\n🎉 All optimization tests passed!")
    } else {
        println("\n⚠️ Some tests failed")
    }

    println("=" * 70)
}

// ================================================================
// Main Test Execution
// ================================================================

fn main() {
    println("╔" + "=" * 68 + "╗")
    println("║ FreeLang IR v1.0 - Runtime Optimization Test Suite             ║")
    println("╚" + "=" * 68 + "╝")

    // Unit Tests
    test_constant_folding_add()
    test_constant_folding_mul()

    test_dead_code_nop_removal()
    test_dead_code_multiple_nops()

    test_instruction_combining_duplicate_load()
    test_instruction_combining_allocate_load()

    // Integration Tests
    test_combined_constant_folding_and_dead_code()
    test_full_optimization_pipeline()

    // Performance Tests
    test_performance_large_program()

    // Correctness Tests
    test_correctness_optimization_preserves_semantics()

    // Edge Cases
    test_empty_program_optimization()
    test_single_instruction_optimization()
    test_no_optimization_opportunity()

    // Configuration Tests
    test_disable_optimizations()

    // Summary
    print_test_summary()
}

main()
